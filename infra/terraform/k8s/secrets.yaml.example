# ──────────────────────────────────────────────
# Kubernetes Secrets Template
# ──────────────────────────────────────────────
# ⚠️  DO NOT commit this file with real values!
#
# Usage:
#   1. Copy this file:  cp secrets.yaml.example secrets.yaml
#   2. Replace <BASE64_ENCODED_VALUE> placeholders
#   3. Apply:           kubectl apply -f secrets.yaml
#
# To base64 encode a value:
#   echo -n "your-value" | base64
# ──────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: hiring-system-secrets
  namespace: services
type: Opaque
data:
  # echo -n "sk-your-openai-key" | base64
  openai-api-key: <BASE64_ENCODED_VALUE>
  # echo -n "hiring-system-dev-postgres.xxxxxxxxxx.ap-southeast-1.rds.amazonaws.com" | base64
  db-host: <BASE64_ENCODED_VALUE>
  # echo -n "dbadmin" | base64
  db-username: <BASE64_ENCODED_VALUE>
  # echo -n "your-db-password" | base64
  db-password: <BASE64_ENCODED_VALUE>
